<Window x:Class="McfEditor.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About McfEditor"
        Width="520"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource AppPanelBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="18">
            <StackPanel>
                <TextBlock Text="McfEditor"
                           FontSize="24"
                           FontWeight="SemiBold"/>
                <TextBlock Text="MCF extraction, preview and rebuild tool for MIB2 image archives."
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Startup package based on your GcaEditor project structure and dark theme."
                           Margin="0,14,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Current status:"
                           Margin="0,18,0,6"
                           FontWeight="SemiBold"/>
                <TextBlock Text="• Open an MCF file&#x0a;• Extract all images through Python backend&#x0a;• Preview and replace PNGs&#x0a;• Rebuild a new MCF file&#x0a;• Settings, release script and notes included"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    Width="90"
                    IsDefault="True"
                    Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
