<Window x:Class="McfEditor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:McfEditor"
        xmlns:models="clr-namespace:McfEditor.Models"
        mc:Ignorable="d"
        Title="McfEditor"
        Width="1100"
        Height="700"
        MinWidth="1100"
        MinHeight="700"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource AppPanelBrush}"
              Foreground="{DynamicResource AppTextBrush}">
            <MenuItem Header="_File">
                <MenuItem Header="_Open MCF..."
                          InputGestureText="Ctrl+O"
                          Click="OpenMcf_Click"/>
                <Separator/>
                <MenuItem Header="_Extract / reload"
                          Click="ExtractAll_Click"/>
                <MenuItem Header="_Rebuild MCF..."
                          Click="RebuildMcf_Click"/>
                <Separator/>
                <MenuItem Header="_Open working folder"
                          Click="OpenWorkingFolder_Click"/>
                <Separator/>
                <MenuItem Header="_Exit"
                          Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="{Binding UndoMenuHeader}"
                          Command="{x:Static local:MainWindow.UndoProjectCommand}"
                          InputGestureText="Ctrl+Z"/>
                <MenuItem Header="{Binding RedoMenuHeader}"
                          Command="{x:Static local:MainWindow.RedoProjectCommand}"
                          InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_Tools">
                <MenuItem Header="_Settings..."
                          Click="Settings_Click"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_Check for updates"
                          Click="CheckUpdate_Click"/>
                <Separator/>
                <MenuItem Header="_About"
                          Click="About_Click"/>
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource AppPanelBrush}"
                   Foreground="{DynamicResource AppTextBrush}">
            <StatusBarItem>
                <TextBlock x:Name="StatusTextBlock" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Margin="12,12,12,0"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="Open MCF" Click="OpenMcf_Click"/>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="2"
                             Height="34"
                             VerticalContentAlignment="Center"
                             ToolTip="Search by index or name"
                             TextChanged="SearchBox_TextChanged"/>
                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                        <Button Content="Extract / reload" Margin="0,0,8,0" Click="ExtractAll_Click"/>
                        <Button Content="Rebuild MCF" Click="RebuildMcf_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="340"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource AppPanelBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock x:Name="CurrentFileLabel"
                                       Text="File: -"
                                       Foreground="{DynamicResource AppMutedTextBrush}"/>
                            <TextBlock x:Name="CurrentWorkLabel"
                                       Text="Workdir: -"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <GroupBox Grid.Row="2" Header="Images">
                            <Border Background="{DynamicResource AppPanelAltBrush}"
        BorderBrush="{DynamicResource AppBorderBrush}"
        BorderThickness="1"
        CornerRadius="10"
        Padding="4"
        SnapsToDevicePixels="True">
                                <TreeView x:Name="ImagesTreeView"
              ItemsSource="{Binding ExplorerNodes}"
              SelectedItemChanged="ImagesTreeView_SelectedItemChanged"
              Style="{StaticResource DarkTreeViewStyle}">
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type models:ExplorerNode}"
                                      ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal">
                                                <Image Width="16"
                           Height="16"
                           Margin="0,0,6,0"
                           VerticalAlignment="Center">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <Setter Property="Source" Value="/Assets/image.png"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                                                                    <Setter Property="Source" Value="/Assets/folder.png"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>

                                                <TextBlock Text="{Binding Name}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource AppTextBrush}"/>
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.Resources>

                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem"
                   BasedOn="{StaticResource DarkTreeViewItemStyle}">
                                            <Setter Property="IsExpanded"
                        Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <Setter Property="IsSelected"
                        Value="{Binding IsSelected, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                </TreeView>
                            </Border>
                        </GroupBox>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource AppPanelBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="PreviewTitleText"
                                   Text="Preview"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <Border Grid.Row="2"
                                Background="{DynamicResource AppPanelAltBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="12">
                            <Grid Background="Transparent">
                                <Viewbox Stretch="Uniform"
                                            StretchDirection="DownOnly"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                    <Image x:Name="PreviewImage"
                                                Stretch="None"
                                                SnapsToDevicePixels="True"
                                                RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Viewbox>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="4"
                                   x:Name="PreviewHintText"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Open an MCF file to start."/>
                    </Grid>
                </Border>

                <Border Grid.Column="4"
                        Background="{DynamicResource AppPanelBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Properties"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" x:Name="SelectedIndexText" Text="Index: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="3" x:Name="SelectedStatusText" Text="Status: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="4" x:Name="SelectedDimensionsText" Text="Dimensions: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="5" x:Name="SelectedModeText" Text="Mode: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="6" x:Name="SelectedOffsetText" Text="Offset: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="7" x:Name="SelectedSizeText" Text="Compressed size: -" Margin="0,0,0,8"/>
                        <TextBlock Grid.Row="8" x:Name="SelectedPathText"
                                   Text="Path: -"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>

                        <StackPanel Grid.Row="10">
                            <Button Content="Replace image..." Click="ReplaceImage_Click"/>
                            <Button Content="Restore original" Margin="0,8,0,0" Click="RestoreImage_Click"/>
                        </StackPanel>

                        <StackPanel Grid.Row="12">
                            <Button Content="Open working folder" Click="OpenWorkingFolder_Click"/>
                            <Button Content="Rebuild MCF..." Margin="0,8,0,0" Click="RebuildMcf_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
