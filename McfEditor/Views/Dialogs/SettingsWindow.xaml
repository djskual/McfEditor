<Window x:Class="McfEditor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="860"
        Height="560"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppWindowBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="10">
                <ListBox x:Name="SectionList"
                         SelectionChanged="SectionList_SelectionChanged">
                    <ListBoxItem Content="General" IsSelected="True"/>
                    <ListBoxItem Content="Python backend"/>
                    <ListBoxItem Content="Output"/>
                    <ListBoxItem Content="Updates"/>
                </ListBox>
            </Border>

            <Border Grid.Column="2"
                    Background="{DynamicResource AppPanelBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="14"
                    Padding="18">
                <Grid x:Name="SectionHost">
                    <StackPanel x:Name="GeneralPanel">
                        <TextBlock Text="General"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>
                        <CheckBox x:Name="RememberWindowPlacementCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Remember window size and position"/>
                    </StackPanel>

                    <StackPanel x:Name="PythonPanel" Visibility="Collapsed">
                        <TextBlock Text="Python backend"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>
                        <TextBlock Text="Python executable"
                                   Foreground="{DynamicResource AppMutedTextBrush}"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="PythonPathTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Browse" Click="BrowsePython_Click"/>
                        </Grid>

                        <CheckBox x:Name="UseImageIdMapWhenAvailableCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Use imageidmap.res when available"
                                  Margin="0,10,0,0"/>
                        <CheckBox x:Name="AskBeforeUsingImageIdMapCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Ask before using imageidmap.res"
                                  Margin="0,10,0,0"/>
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="These options control whether imageidmap.res is used to organize extracted images and build the explorer tree."/>
                    </StackPanel>

                    <StackPanel x:Name="OutputPanel" Visibility="Collapsed">
                        <TextBlock Text="Output"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="OpenWorkingFolderCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Open working folder automatically after extraction"/>

                        <TextBlock Text="Default output folder"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Margin="0,16,0,0"/>
                        <Grid Margin="0,6,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="90"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DefaultOutputFolderTextBox" Grid.Column="0" Height="32" VerticalContentAlignment="Center"/>
                            <Button Grid.Column="2" Content="Browse" Click="BrowseOutputFolder_Click"/>
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="UpdatesPanel" Visibility="Collapsed">
                        <TextBlock Text="Updates"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,14"/>

                        <CheckBox x:Name="AutoCheckUpdatesCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Check for updates automatically at startup"/>

                        <CheckBox x:Name="IncludePrereleaseCheck"
                                  Style="{StaticResource LabeledCheckBoxStyle}"
                                  Content="Include prerelease versions in update checks"
                                  Margin="0,10,0,0"/>

                        <TextBlock Margin="0,12,0,0"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="When enabled, beta and prerelease versions are considered during update checks."/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="Cancel"
                    Width="90"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Save"
                    Width="90"
                    IsDefault="True"
                    Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>
